        <div><div class="link-name">Inforce CRM</div><div class="link-sub">aeaimoveis</div></div>
      </a>
      <a class="link-card" href="https://www.orulo.com.br" target="_blank" data-name="Órulo Portal">
        <div class="icon">🏗️</div>
        <div><div class="link-name">Órulo</div><div class="link-sub">Portal de imóveis</div></div>
      </a>
      <a class="link-card" href="https://app.asana.com" target="_blank" data-name="Asana tarefas">
        <div class="icon">📋</div>
        <div><div class="link-name">Asana</div><div class="link-sub">Tarefas & CRM</div></div>
      </a>
      <a class="link-card" href="https://www.lopesnet.com.br" target="_blank" data-name="Lopes Rio">
        <div class="icon">🔑</div>
        <div><div class="link-name">Lopes Rio</div><div class="link-sub">Portal interno</div></div>
      </a>
    </div>
  </div>

  <div class="category">
    <div class="cat-label">Incorporadoras & Lançamentos</div>
    <div class="grid wide">
      <a class="link-card" href="https://www.calper.com.br" target="_blank" data-name="Calper incorporadora">
        <div class="icon">🏛️</div>
        <div><div class="link-name">Calper</div><div class="link-sub">Incorporadora</div></div>
      </a>
      <a class="link-card" href="https://www.btgpactual.com" target="_blank" data-name="BTG Pactual">
        <div class="icon">🏦</div>
        <div><div class="link-name">BTG Pactual</div><div class="link-sub">Incorporadora</div></div>
      </a>
      <a class="link-card" href="https://www.opportunity.com.br" target="_blank" data-name="Opportunity incorporadora">
        <div class="icon">🏢</div>
        <div><div class="link-name">Opportunity</div><div class="link-sub">Incorporadora</div></div>
      </a>
    </div>
  </div>

  <div class="category">
    <div class="cat-label">Redes Sociais</div>
    <div class="grid">
      <a class="link-card" href="https://www.instagram.com/alexandredamasceno.corretor" target="_blank" data-name="Instagram trabalho corretor">
        <div class="icon">📸</div>
        <div><div class="link-name">Instagram</div><div class="link-sub">@corretor</div></div>
      </a>
      <a class="link-card" href="https://www.instagram.com/alexandre.d.nascimento" target="_blank" data-name="Instagram pessoal">
        <div class="icon">🤳</div>
        <div><div class="link-name">Instagram</div><div class="link-sub">@pessoal</div></div>
      </a>
      <a class="link-card" href="https://www.facebook.com/alexandre.damasceno.nascimento" target="_blank" data-name="Facebook pessoal">
        <div class="icon">👤</div>
        <div><div class="link-name">Facebook</div><div class="link-sub">Pessoal</div></div>
      </a>
      <a class="link-card" href="https://www.facebook.com" target="_blank" data-name="Facebook trabalho">
        <div class="icon">📘</div>
        <div><div class="link-name">Facebook</div><div class="link-sub">Trabalho</div></div>
      </a>
      <a class="link-card" href="https://www.tiktok.com/@alexandrecorretor106899" target="_blank" data-name="TikTok corretor">
        <div class="icon">🎵</div>
        <div><div class="link-name">TikTok</div><div class="link-sub">@corretor106899</div></div>
      </a>
      <a class="link-card" href="https://web.whatsapp.com" target="_blank" data-name="WhatsApp Web">
        <div class="icon">💬</div>
        <div><div class="link-name">WhatsApp</div><div class="link-sub">Web</div></div>
