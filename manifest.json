      </a>
      <a class="link-card" href="https://chat.deepseek.com" target="_blank" data-name="DeepSeek IA">
        <div class="icon">🔬</div>
        <div><div class="link-name">DeepSeek</div><div class="link-sub">IA</div></div>
      </a>
    </div>
  </div>

  <div class="category">
    <div class="cat-label">Criação & Design</div>
    <div class="grid">
      <a class="link-card" href="https://www.canva.com" target="_blank" data-name="Canva design gráfico">
        <div class="icon">🎨</div>
        <div><div class="link-name">Canva</div><div class="link-sub">Design</div></div>
