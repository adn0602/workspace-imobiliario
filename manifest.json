      </a>
      <a class="link-card" href="https://chatgpt.com" target="_blank" data-name="ChatGPT OpenAI">
        <div class="icon">💡</div>
        <div><div class="link-name">ChatGPT</div><div class="link-sub">OpenAI</div></div>
      </a>
      <a class="link-card" href="https://gemini.google.com" target="_blank" data-name="Gemini Google IA">
