<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Alexandre | Painel de Links</title>

  <link rel="manifest" href="manifest.json">
  <meta name="theme-color" content="#f5f0eb">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="default">
  <meta name="apple-mobile-web-app-title" content="Meus Links">
  <link rel="apple-touch-icon" href="icon-192.png">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Jost:wght@300;400;500&family=Share+Tech+Mono&display=swap" rel="stylesheet">

  <style>
    :root {
      --bg: #f7f4f0;
      --bg2: #eeeae4;
      --surface: #ffffff;
      --border: rgba(0,0,0,0.08);
      --border2: rgba(0,0,0,0.04);
      --gold: #b8955a;
      --gold-light: #d4b483;
      --text: #1a1714;
      --muted: #9a9088;
      --shadow: rgba(0,0,0,0.06);
      --shadow2: rgba(0,0,0,0.12);
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'Jost', sans-serif;
      min-height: 100vh;
      overflow-x: hidden;
    }

    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background:
        radial-gradient(ellipse 70% 50% at 0% 0%, rgba(184,149,90,0.08) 0%, transparent 60%),
        radial-gradient(ellipse 50% 40% at 100% 100%, rgba(184,149,90,0.05) 0%, transparent 60%);
      pointer-events: none;
      z-index: 0;
    }

    .container {
      position: relative;
      z-index: 1;
      max-width: 860px;
      margin: 0 auto;
      padding: 52px 24px 80px;
    }

    header {
      text-align: center;
      margin-bottom: 44px;
    }

    .monogram {
      width: 64px;
      height: 64px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--gold), var(--gold-light));
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 20px;
      box-shadow: 0 4px 20px rgba(184,149,90,0.25);
    }

    .monogram span {
      font-family: 'Cormorant Garamond', serif;
      font-size: 28px;
      font-weight: 600;
      color: #fff;
      letter-spacing: 0.02em;
    }

    header h1 {
      font-family: 'Cormorant Garamond', serif;
      font-size: 30px;
      font-weight: 300;
      letter-spacing: 0.14em;
      color: var(--text);
      text-transform: uppercase;
    }

    header p {
      font-family: 'Jost', sans-serif;
      font-size: 10px;
      font-weight: 300;
      color: var(--muted);
      margin-top: 6px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
    }

    .divider {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 12px;
      margin: 18px auto 0;
    }

    .divider::before,
    .divider::after {
      content: '';
      width: 40px;
      height: 1px;
      background: linear-gradient(90deg, transparent, var(--gold));
    }

    .divider::after {
      background: linear-gradient(90deg, var(--gold), transparent);
    }

    .divider-diamond {
      width: 5px;
      height: 5px;
      background: var(--gold);
      transform: rotate(45deg);
    }

    .clock {
      text-align: center;
      margin-bottom: 36px;
    }

    .clock-time {
      font-family: 'Share Tech Mono', monospace;
      font-size: 58px;
      font-weight: 400;
      color: var(--text);
      letter-spacing: 0.04em;
      line-height: 1;
    }

    .clock-date {
      font-family: 'Jost', sans-serif;
      font-size: 10px;
      font-weight: 300;
      color: var(--muted);
      margin-top: 8px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
    }

    .search-wrap {
      margin-bottom: 40px;
    }

    .search-wrap input {
      width: 100%;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 4px;
      padding: 13px 20px;
      color: var(--text);
      font-family: 'Jost', sans-serif;
      font-size: 13px;
      font-weight: 300;
      letter-spacing: 0.06em;
      outline: none;
      transition: border-color 0.3s, box-shadow 0.3s;
      box-shadow: 0 2px 8px var(--shadow);
    }

    .search-wrap input::placeholder { color: var(--muted); }
    .search-wrap input:focus {
      border-color: var(--gold-light);
      box-shadow: 0 2px 16px rgba(184,149,90,0.12);
    }

    .category { margin-bottom: 36px; }

    .cat-label {
      font-family: 'Jost', sans-serif;
      font-size: 9px;
      font-weight: 500;
      letter-spacing: 0.24em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 14px;
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .cat-label::after {
      content: '';
      flex: 1;
      height: 1px;
      background: linear-gradient(90deg, var(--border), transparent);
    }

    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(155px, 1fr));
      gap: 10px;
    }

    .grid.wide {
      grid-template-columns: repeat(auto-fill, minmax(190px, 1fr));
    }

    .link-card {
      display: flex;
      align-items: center;
      gap: 12px;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 4px;
      padding: 13px 15px;
      text-decoration: none;
      color: var(--text);
      transition: all 0.25s ease;
      position: relative;
      overflow: hidden;
      box-shadow: 0 2px 8px var(--shadow);
    }

    .link-card::before {
      content: '';
      position: absolute;
      left: 0; top: 0; bottom: 0;
      width: 2px;
      background: linear-gradient(180deg, var(--gold), var(--gold-light));
      opacity: 0;
      transition: opacity 0.25s;
    }

    .link-card:hover {
      border-color: rgba(184,149,90,0.25);
      transform: translateY(-2px);
      box-shadow: 0 8px 24px var(--shadow2);
    }

    .link-card:hover::before { opacity: 1; }
    .link-card:active { transform: translateY(0); }

    .icon {
      width: 32px;
      height: 32px;
      border-radius: 3px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 16px;
      flex-shrink: 0;
      background: var(--bg2);
    }

    .link-name {
      font-family: 'Jost', sans-serif;
      font-size: 13px;
      font-weight: 400;
      letter-spacing: 0.02em;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .link-sub {
      font-size: 10px;
      font-weight: 300;
      color: var(--muted);
      margin-top: 2px;
      letter-spacing: 0.03em;
    }

    .link-card.hidden { display: none; }
  </style>
</head>
<body>
<div class="container">

  <header>
    <div class="monogram"><span>A</span></div>
    <h1>Alexandre Damasceno</h1>
    <p>Consultor Imobiliário &nbsp;·&nbsp; CRECI 106.899</p>
    <div class="divider"><div class="divider-diamond"></div></div>
  </header>

  <div class="clock">
    <div class="clock-time" id="clock">--:--</div>
    <div class="clock-date" id="date">--</div>
  </div>

  <div class="search-wrap">
    <input type="text" id="search" placeholder="⌕  Buscar link..." oninput="filterLinks(this.value)">
  </div>

  <div class="category">
    <div class="cat-label">Trabalho Imobiliário</div>
    <div class="grid wide">
      <a class="link-card" href="https://aeaimoveis.inforcedata.com.br" target="_blank" data-name="Inforce CRM">
